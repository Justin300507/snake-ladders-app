        "user_stories": [
            {
                "role": "Player",
                "want": "to create a new game lobby",
                "acceptance_criteria": [
                    "A lobby is created with a unique 6\u2011character code",
                    "Lobby shows the creator as Player\u202f1 and allows up to 4 total players",
                    "Lobby status changes to \"waiting\" until at least 2 players have joined"
                ]
            },
            {
                "role": "Player",
                "want": "to join an existing lobby using a code",
                "acceptance_criteria": [
                    "Entering a valid code adds the user to the lobby and shows the updated player list",
                    "Joining fails with an error if the lobby is full or the code is invalid",
                    "After joining, the user sees a \"Ready\" button to confirm participation"
                ]
            },
            {
                "role": "Player",
                "want": "to roll the dice on my turn",
                "acceptance_criteria": [
                    "Dice roll generates a random integer between 1 and 6 inclusive",
                    "The token animates to the new square, applying any snake or ladder immediately",
                    "If the roll would exceed square\u202f100, the token does not move"
                ]
            },
            {
                "role": "Player",
                "want": "to see other players' moves in real time",
                "acceptance_criteria": [
                    "Board updates for other players' moves within 1\u202fsecond of their action",
                    "Each player\u2019s token is displayed with a distinct color and label",
                    "No duplicate or out\u2011of\u2011order moves appear on the board"
                ]
            },
            {
                "role": "Player",
                "want": "to play against an AI opponent when no friends are available",
                "acceptance_criteria": [
                    "AI selects a legal move within 500\u202fms after its turn begins",
                    "Difficulty levels (Easy, Medium, Hard) affect the probability of the AI taking optimal moves",
                    "Game ends correctly when the AI reaches square\u202f100"
                ]
            },
            {
                "role": "User",
                "want": "to sign up and log in",
                "acceptance_criteria": [
                    "Sign\u2011up requires a unique email, password (min\u202f8\u202fchars), and optional display name",
                    "Login returns a JWT that is stored securely on the client",
                    "Authenticated sessions persist for at least 30\u202fdays unless the user logs out"
                ]
            },
            {
                "role": "User",
                "want": "to view my game history and win/loss statistics",
                "acceptance_criteria": [
                    "History endpoint returns a paginated list (20 items per page) sorted by most recent",
                    "Each entry shows date, opponent type (human/AI), final position, and win/loss result",
                    "Statistics page aggregates total games, wins, losses, and win percentage"
                ]
            },
            {
                "role": "Parent",
                "want": "to create a child account with restricted chat",
                "acceptance_criteria": [
                    "Parent can create a sub\u2011account linked to their own user ID",
                    "Child accounts cannot send chat messages; they can only view system notifications",
                    "Parent can toggle the restriction on/off from the account settings"
                ]
            },
            {
                "role": "Player",
                "want": "to customize board appearance (theme & sound)",
                "acceptance_criteria": [
                    "Settings screen offers at least three visual themes and a sound on/off toggle",
                    "Chosen theme persists across sessions for the logged\u2011in user",
                    "Changing a setting updates the UI instantly without requiring a reload"
                ]
            }
        ],
        "non_functional_requirements": {
            "authentication": "required \u2014 all game\u2011related endpoints must verify a JWT to protect user data and prevent cheating",
            "authorization": "role\u2011based: regular users, parent users, and child users (child cannot send chat messages)",
            "pagination": "required on /games/history and /leaderboard endpoints",
            "search": "users can be searched by display name for friend invites",
            "file_uploads": "no \u2014 avatars are optional and stored as URL strings; no binary upload handling needed",
            "real_time": "yes \u2014 WebSocket channel for board state updates and chat messages"
